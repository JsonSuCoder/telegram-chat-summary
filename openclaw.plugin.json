{
  "id": "telegram-chat-summary",
  "name": "Telegram Chat Summary",
  "description": "Lists Telegram chats, configures summary monitoring, and runs AI summaries for Telegram conversations.",
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": [],
    "properties": {
      "apiId": {
        "type": "number",
        "description": "Telegram API ID from https://my.telegram.org"
      },
      "apiHash": {
        "type": "string",
        "description": "Telegram API Hash from https://my.telegram.org"
      },
      "sessionString": {
        "type": "string",
        "description": "Session string generated by `openclaw telegram-chat-summary setup`"
      },
      "chats": {
        "type": "array",
        "description": "List of chats to summarize",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["chatId"],
          "properties": {
            "chatId": {
              "type": ["string", "number"],
              "description": "Telegram chat ID or @username"
            },
            "label": {
              "type": "string",
              "description": "Human-readable label for logs"
            }
          }
        }
      },
      "schedulerEnabled": {
        "type": "boolean",
        "description": "Whether the background summary scheduler is enabled (default: true)"
      },
      "scheduleMinutes": {
        "type": "number",
        "description": "How often to summarize all chats, in minutes (default: 60)"
      },
      "language": {
        "type": "string",
        "description": "Language for summaries (default: zh-CN)"
      },
      "maxMessagesPerFetch": {
        "type": "number",
        "description": "Max messages to fetch per chat per run (default: 500)"
      },
      "summaryPrompt": {
        "type": "string",
        "description": "Custom prompt template. Placeholders: {messages} {language} {timeRange} {chatTitle}"
      },
      "botToken": {
        "type": "string",
        "description": "Send all summaries via this bot token instead of user account"
      },
      "alertChatId": {
        "type": ["string", "number"],
        "description": "Personal chat ID to receive bot summaries (your Telegram user ID)"
      },
      "proxy": {
        "type": "object",
        "additionalProperties": false,
        "required": ["host", "port"],
        "description": "SOCKS proxy for MTProto connection",
        "properties": {
          "host": { "type": "string" },
          "port": { "type": "number" },
          "socksType": { "type": "number", "enum": [4, 5] },
          "username": { "type": "string" },
          "password": { "type": "string" }
        }
      }
    }
  },
  "uiHints": {
    "apiId": {
      "label": "API ID",
      "placeholder": "12345678"
    },
    "apiHash": {
      "label": "API Hash",
      "placeholder": "0123456789abcdef0123456789abcdef",
      "sensitive": true
    },
    "sessionString": {
      "label": "Session String",
      "sensitive": true
    }
  }
}
